# ─────────────────────────────────────────────────────────────────────────────
# Environment variables (ALL OPTIONAL).
#
# The single source of truth for configuration is `config/site.config.ts`.
# The variable below is an OPTIONAL override: if set, it takes precedence over
# `config.api.appsScriptUrl`. This is handy on Vercel so you can deploy without
# committing your script URL to the repo.
#
# Copy this file to `.env.local` and fill it in (or just edit site.config.ts).
# Note: NEXT_PUBLIC_* values are exposed to the browser — that is expected here,
# because the Apps Script Web App URL is called directly from the client.
# ─────────────────────────────────────────────────────────────────────────────

# Your deployed Google Apps Script Web App URL (ends with /exec).
NEXT_PUBLIC_APPS_SCRIPT_URL=
